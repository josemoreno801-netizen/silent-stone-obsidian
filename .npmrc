# Scope plugin release tags to `plugin-v<X.Y.Z>` so they don't collide with
# any future server-side release tags (`v<X.Y.Z>` or similar) in the same repo.
# Used by `npm version` when running from this directory.
tag-version-prefix=plugin-v

# Disable npm 7+ peer-dep auto-install. vite (via vitest) declares an
# `esbuild: ^0.27.0 || ^0.28.0` peer, but the plugin itself pins
# `esbuild: ^0.25.0`. Without this flag, npm 11 quietly nests the newer
# esbuild as "extraneous" in the lockfile — a shape npm 10 on CI barfs on
# with EBADPLATFORM errors trying to install AIX/PPC platform packages.
# Keeping peers legacy keeps the lockfile flat and portable.
legacy-peer-deps=true
