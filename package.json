{
	"name": "silent-stone-sync",
	"version": "0.1.2",
	"description": "Encrypted vault sync through your private Silent Stone server.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "node esbuild.config.mjs production",
		"lint": "eslint src/",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"version": "node scripts/sync-version.mjs && git add manifest.json versions.json",
		"postversion": "git push --follow-tags",
		"install-to-vault": "bash scripts/install-to-vault.sh"
	},
	"keywords": [
		"obsidian-plugin",
		"sync",
		"encryption"
	],
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^22.0.0",
		"builtin-modules": "^4.0.0",
		"esbuild": "^0.25.0",
		"eslint": "^9.0.0",
		"obsidian": "latest",
		"typescript": "~5.7.0",
		"vitest": "^4.1.3"
	},
	"dependencies": {
		"@noble/hashes": "^2.0.1",
		"@scure/bip39": "^2.0.1"
	}
}
